   "source": [
    "from qiskit import QuantumCircuit\n",
    "from qiskit_aer.primitives import Sampler\n",
    "\n",
    "# Build a simple circuit\n",
    "qc = QuantumCircuit(1, 1)\n",
    "qc.h(0)\n",
    "qc.measure(0, 0)\n",
    "\n",
    "# Run with Sampler\n",
    "sampler = Sampler()\n",
    "result = sampler.run(qc, shots=1024).result()\n",
    "\n",
    "print(result)\n"
   ]
  }
 ],
